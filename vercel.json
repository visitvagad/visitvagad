{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://visitvagad.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_CLERK_PUBLISHABLE_KEY": "@vite_clerk_key",
    "VITE_API_URL": "@vite_api_url"
  },
  "envPrefix": "VITE_"
}
