# ===== SERVER CONFIGURATION =====
PORT=5000
NODE_ENV=production

# ===== MONGODB ATLAS =====
# Get this from MongoDB Atlas: Databases > Connect > Drivers > Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/visitvagad
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/visitvagad?retryWrites=true&w=majority

# ===== JWT AUTHENTICATION =====
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# ===== CLERK AUTHENTICATION =====
# Get from: https://dashboard.clerk.com > API Keys > Copy keys
CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key

# ===== IMAGEKIT CONFIGURATION =====
# Get from: https://imagekit.io > Developer Options
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ===== CORS (Frontend URL) =====
# Update to your production frontend URL after deployment
CORS_ORIGIN=http://localhost:5173
